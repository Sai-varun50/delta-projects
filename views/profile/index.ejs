<% layout("/listings/layouts/boilerplate") %>
<div class="container mt-4">

    <h2>My Dashboard</h2>
    <div class="row mb-4">

    <div class="col-md-6 mb-3">
        <div class="card bg-primary text-white shadow border-0">
            <div class="card-body text-center">
                <h5>Total Listings</h5>
                <h1><%= totalListings %></h1>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card bg-success text-white shadow border-0">
            <div class="card-body text-center">
                <h5>Total Bookings</h5>
                <h1><%= totalBookings %></h1>
            </div>
        </div>
    </div>

</div>
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">

        <div>
            <h3 class="mb-1">
                Welcome,
                <%= currentUser.username %> 👋
            </h3>

            <p class="text-muted mb-0">
            <%= currentUser.email %>            </p>
        </div>

        <div class="mt-3 mt-md-0">

            <a href="/listings/new" class="btn btn-success me-2">
                <i class="fa-solid fa-plus"></i>
                Add Listing
            </a>

            <a href="/wishlist" class="btn btn-outline-danger me-2">
                ❤️ Wishlist
            </a>

            <a href="/listings" class="btn btn-dark">
                Explore
            </a>

        </div>

    </div>
</div>
    <hr>

    <h3>My Listings</h3>

   <div class="row card shadow border-0 rounded-4 h-100">

<% if(listings.length === 0){ %>

    <div class="col-12">
        <div class="alert alert-info text-center">
            You haven't created any listings yet.
        </div>
    </div>

<% } else { %>

    <% listings.forEach(listing => { %>

        <div class="col-md-4 mb-3">

            <div class="card shadow border-0 rounded-4 h-100">

                <img src="<%= listing.image.url %>" class="card-img-top">

                <div class="card-body">

                    <h5><%= listing.title %></h5>

                    <a href="/listings/<%= listing._id %>" class="btn btn-dark">
                        View
                    </a>

                </div>

            </div>

        </div>

    <% }) %>

<% } %>

</div>

    <hr>

    <h3>My Bookings</h3>

   <div class="row card shadow border-0 rounded-4 h-100">

<% if(bookings.length === 0){ %>

    <div class="col-12">
        <div class="alert alert-warning text-center">
            No bookings found.
        </div>
    </div>

<% } else { %>

    <% bookings.forEach(booking => { %>

        <div class="col-md-4 mb-3">

            <div class="card">

                <img src="<%= booking.listing.image.url %>" class="card-img-top">

                <div class="card-body">

                    <h5><%= booking.listing.title %></h5>

                    <p>Guests: <%= booking.guests %></p>

                    <p>₹<%= booking.totalPrice %></p>

                </div>

            </div>

        </div>

    <% }) %>

<% } %>

</div>

</div>

