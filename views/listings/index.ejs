<% layout("listings/layouts/boilerplate.ejs") -%> 
<body>
    

      <style>
        
      </style>


<div id="filters">

  <a href="/listings" class="listing-link text-decoration-none">
    <div class="filter <%= !category ? 'active-filter' : '' %>">
      <div><i>🔥</i></div>
      <p>All</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Mountains" class="text-decoration-none">    <div class="filter <%= category === 'Mountains'  ? 'active-filter' : '' %>">
      <div><i>🏔️</i></div>
      <p>Mountains</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Camping" class="text-decoration-none">    <div class="filter <%= category === 'Camping' ? 'active-filter' : '' %>">
      <div><i>🏕️</i></div>
      <p>Camping</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Castle" class="text-decoration-none">    <div class="filter <%= category === 'Castle' ? 'active-filter' : '' %>">
      <div><i>🏰</i></div>
      <p>Castle</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Beach" class="text-decoration-none">    <div class="filter <%= category === 'Beach' ? 'active-filter' : '' %>">
      <div><i>🏖️</i></div>
      <p>Beach</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Forest" class="text-decoration-none">    <div class="filter <%= category === 'Forest' ? 'active-filter' : '' %>">
      <div><i>🌲</i></div>
      <p>Forest</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Desert" class="text-decoration-none">    <div class="filter <%= category === 'Desert' ? 'active-filter' : '' %>">
      <div><i>🏜️</i></div>
      <p>Desert</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Farm" class="text-decoration-none">    <div class="filter <%= category === 'Farm' ? 'active-filter' : '' %>">
      <div><i>🚜</i></div>
      <p>Farm</p>
    </div>
  </a>

<a href="/listings?search=<%= search || '' %>&category=Iconic Cities" class="text-decoration-none">    <div class="filter <%= category === 'Iconic Cities' ? 'active-filter' : '' %>">
      <div><i>🌆</i></div>
      <p>Cities</p>
    </div>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="switchCheckDefault"
      >
      <label class="form-check-label" for="switchCheckDefault">
        Display total after taxes
      </label>
    </div>
  </div>

</div>
<% if(alllistings.length === 0){ %>

<div class="text-center mt-5">
    <h2>😕 No places found</h2>

    <p>Try another destination or category.</p>

    <a href="/listings" class="btn btn-dark">
        Back to All Listings
    </a>
</div>

<% } else { %>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">  <% for(let listing of alllistings) { %>

    <div class="col " >
      <a href="/listings/<%= listing._id %>" class="listing-link ">      



        <div class="card  listing-card" style="width: 25rem; margin: 20px;">
          <% if(currentUser && userWishlist.includes(listing._id.toString())) { %>

<form action="/wishlist/<%= listing._id %>?_method=DELETE" method="POST">
    <button
        type="submit"
        class="wishlist-btn"
        onclick="event.stopPropagation()">
        ❤️
    </button>
</form>

<% } else { %>

<form action="/wishlist/<%= listing._id %>" method="POST">
    <button
        type="submit"
        class="wishlist-btn"
        onclick="event.stopPropagation()">
        🤍
    </button>
</form>

<% } %>
          <img src="<%= listing.image.url %>" 
               class="card-img-top " 
               alt="listing_image"
               onerror="this.src='https://images.unsplash.com/photo-1464983953574-0892a716854b';"
               style="height:20rem; object-fit:cover;">

          <div class="card-body">
            <b><h5 class="card-title"><%= listing.title %></h5></b>

            <p>
              ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>/night
              <i class="tax-info"> &nbsp; +18% GST </i>
            </p>
                
          </div>

        </div>

      </a>
    </div>
  <% } %>
</div>
<% } %>


<script>
  let taxswitch = document.getElementById("switchCheckDefault")
  taxswitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo) {
      if(info.style.display !="inline"){
        info.style.display = "inline";
      }else {
        info.style.display = "none";
      }
    }
    // console.log("clicked");
  });
</script>
</body>
