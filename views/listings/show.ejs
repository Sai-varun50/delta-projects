<% layout("listings/layouts/boilerplate.ejs") -%>

<body>
    <div class="row mt-3">

        <div class="col-8 offset-2  ">
            <b><h2><%= listing.title %></h2></b> <br>
        </div>

        <div class="card col-6 offset-2 show-card  listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="...">
            
            <div class="card-body">
                <p class="card-text">
                    <i><% if (listing.owner) { %></i>
<div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
    <div class="d-flex align-items-center">

        <div
            class="rounded-circle bg-dark text-white d-flex justify-content-center align-items-center"
            style="width:65px;height:65px;font-size:24px;font-weight:bold;">
            <%= listing.owner.username.charAt(0).toUpperCase() %>
        </div>

        <div class="ms-3">
            <h5 class="mb-1">
                Hosted by <%= listing.owner.username %>
            </h5>

            <p class="text-muted mb-1">
                Member since :
Recently Joined            </p>

            <p class="mb-0">
                🏠 <%= hostListingCount %> Listing<%= hostListingCount !== 1 ? "s" : "" %>
            </p>
        </div>

    </div>
</div>                    <% } else { %>
                                <i>Hosted by Unknown</i>
                        <% } %></p>
                  <p><%= listing.description %></p>
                   <p> ₹<%= listing.price.toLocaleString("en-IN") %> </p>
                    <p><%= listing.location %></p>
                   <p><%= listing.country %></p>
                   
                
            </div>
        </div>
    </div>
<a href="mailto:<%= listing.owner.email %>"
   class="btn btn-outline-dark rounded-pill mt-2">
    Contact Host
</a>



    <!-- ✅ NEW ROW FOR BUTTONS -->
    <%  if (currentUser && currentUser._id.equals(listing.owner._id)) { %>
    <div class="row mt-3 btns">
        <div class="col-6 offset-2 d-flex gap-2">

            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
                Edit
            </a>

            <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn btn-dark">Delete</button>
            </form>

        </div>
        
        <div class="col-6 offset-2 mb-3 listing-card" >
 <% } %>
 <% if (currentUser && !currentUser._id.equals(listing.owner._id)) { %>

<hr>

<h4>Book this Stay</h4>

<form action="/bookings/<%= listing._id %>" method="POST">

    <div class="mb-3">
        <label>Check-in</label>
        <input type="date" name="checkIn" class="form-control" required>
    </div>

    <div class="mb-3">
        <label>Check-out</label>
        <input type="date" name="checkOut" class="form-control" required>
    </div>

    <div class="mb-3">
        <label>Guests</label>
        <input type="number" name="guests" class="form-control" min="1" value="1" required>
    </div>

    <button class="btn btn-success">
        Book Now
    </button>
<div class="card shadow border-0 rounded-4 mt-4">
    <div class="card-body">

        <h4 class="mb-3">
            <i class="fa-solid fa-calendar-check text-success"></i>
            Availability
        </h4>

        <% if (!listing.bookedDates || listing.bookedDates.length === 0) { %>

            <div class="alert alert-success mb-0">
                <i class="fa-solid fa-circle-check"></i>
                This property is available for booking.
            </div>

        <% } else { %>

            <div class="mb-3">
                <span class="badge bg-danger fs-6">
                    <%= listing.bookedDates.length %> Booking(s)
                </span>
            </div>

            <% listing.bookedDates.forEach(date => { %>

                <div class="card mb-2 border-danger">
                    <div class="card-body py-2">

                        <i class="fa-solid fa-calendar-days text-danger"></i>

                        <strong>
                            <%= new Date(date.start).toLocaleDateString() %>
                        </strong>

                        -

                        <strong>
                            <%= new Date(date.end).toLocaleDateString() %>
                        </strong>

                    </div>
                </div>

            <% }) %>

        <% } %>

    </div>
</div>
</form>

<% } %>
 <% if(currentUser) { %>
            <hr>
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <!-- <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label >
                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-control">
                </div> -->

                <div class="mb-3 mt-3" >
                    <label for="rating" class="form-label">Rating</label >
                <fieldset class="starability-slot">


  <!-- <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." /> -->
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 stars</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>
                <div>
                    <label for="review" class="form-label">Review</label>
                    <textarea name="review[comment]" id="review" cols="30" rows="10" class="form-control" required></textarea>
                </div class="mb-3 mt-3">
                <br>
                <button class="btn btn-outline-dark" type="submit">Submit Review</button>
                <br>
            </form>
            <% }  %>
            

            <hr>
<div class="d-flex align-items-center justify-content-between mb-3">
    <h3 class="mb-0">Reviews</h3>

    <div class="badge bg-warning text-dark fs-6 px-3 py-2">
        ⭐ <%= averageRating %> | <%= totalReviews %> Review<%= totalReviews !== 1 ? "s" : "" %>
    </div>
</div>        <ul> 
            <div class="row">

<% if (listing.reviews.length === 0) { %>

<div class="col-12">
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
        <h4>⭐ No Reviews Yet</h4>
        <p class="text-muted">
            Be the first to review this amazing place!
        </p>
    </div>
</div>

<% } else { %>

            <% for (let review of listing.reviews) { %>
<div class="card shadow-sm border-0 rounded-4 col-md-5 ms-3 mb-4 review-card">                    <div class="card-body">

<div class="d-flex align-items-center mb-2">
    <div class="rounded-circle bg-dark text-white d-flex justify-content-center align-items-center"
         style="width:45px;height:45px;font-weight:bold;">
        <%= review.author.username.charAt(0).toUpperCase() %>
    </div>

    <div class="ms-3">
        <h6 class="mb-0">@<%= review.author.username %></h6>
    </div>
</div>                        <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                        <p class="card-text"><%= review.comment %></p>
                        <p class="text-muted small mb-0">
    Reviewed on <%= new Date(review.createdAt).toLocaleDateString("en-IN", {
        day: "numeric",
        month: "long",
        year: "numeric"
    }) %>
</p>
                        <!-- <p class="card-text"><%= review.rating %> stars </p> -->
                        
                    </div>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="POST" >
                        <button class="btn btn-dark">Delete</button>
                    </form>
                </div>
            <% } %>
            <% } %>   <!-- closes else block -->

            </div>
        </ul>
            
        </div>
    </div>
</body>