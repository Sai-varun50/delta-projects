<% layout("listings/layouts/boilerplate.ejs") -%>

<div class="row mt-3">
    <h1 class="text-center ">Sign Up for Wonderlust</h1>
    <div class="col-8 offset-2">

        <form action="/users/signup" method="POST" class="needs-validation" novalidate>

            <div class="mb-3">
                <label for="username" class="form-label">Username</label>

                <input
                    type="text"
                    id="username"
                    name="user[username]"
                    placeholder="Enter username"
                    class="form-control"
                    required
                >

                <div class="valid-feedback">
                    Looks good!
                </div>
            </div>

            <!-- Email -->
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>

                <input
                    type="email"
                    id="email"
                    name="user[email]"
                    placeholder="Enter email"
                    class="form-control"
                    required
                >
            </div>
            <!-- Password -->
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>

                <input
                    type="password"
                    id="password"
                    name="user[password]"
                    placeholder="Enter password"
                    class="form-control"
                    required
                >
            </div>

            <button class="btn btn-success" type="submit">
                Sign Up
            </button>

        </form>

    </div>
</div>