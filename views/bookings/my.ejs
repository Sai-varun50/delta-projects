<% layout("listings/layouts/boilerplate.ejs") -%>


<div class="container mt-5">
    <h2 class="mb-4">My Bookings</h2>

    <% if (bookings.length === 0) { %>
        <div class="alert alert-info">
            You haven't made any bookings yet.
        </div>
    <% } else { %>

        <div class="row">
            <% bookings.forEach((booking) => { %>

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow h-100">

                        <img
                            src="<%= booking.listing.image.url %>"
                            class="card-img-top"
                            style="height:220px; object-fit:cover;"
                        >

                        <div class="card-body">

                            <h5><%= booking.listing.title %></h5>

                            <p>
                                <strong>Check-In:</strong>
                                <%= booking.checkIn.toDateString() %>
                            </p>

                            <p>
                                <strong>Check-Out:</strong>
                                <%= booking.checkOut.toDateString() %>
                            </p>

                            <p>
                                <strong>Guests:</strong>
                                <%= booking.guests %>
                            </p>

                            <p>
                                <strong>Total:</strong>
                                ₹<%= booking.totalPrice %>
                            </p>

                            <span class="badge rounded-pill bg-success">
    <i class="fa-solid fa-circle-check"></i>
    <%= booking.status %>
</span>
                                <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST" class="mt-3">
                                    <p class="text-muted small mt-2">
    Booked on:
    <%= booking.createdAt.toLocaleDateString() %>
</p>
    <button class="btn btn-danger w-100">
        Cancel Booking
    </button>
</form>
                        </div>

                    </div>
                </div>

            <% }) %>
        </div>

    <% } %>
</div>

